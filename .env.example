NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used to build absolute URLs in robots.txt/sitemap.xml. Falls back to
# http://localhost:3000 in dev if unset.
NEXT_PUBLIC_SITE_URL=https://flikax.com

# Server-only. Required for "Delete my account permanently" in Settings.
# Get it from Supabase dashboard -> Project Settings -> API -> service_role key.
# NEVER expose this to the client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Master switch for Paystack/Flutterwave + the Featured-listing paid tier.
# Per the build brief, payments are built but must stay OFF until launch Phase 4.
# Leave unset/false until the business is registered and both providers are verified.
PAYMENTS_ENABLED=false

# Server-only. From your Paystack dashboard -> Settings -> API Keys & Webhooks.
PAYSTACK_SECRET_KEY=

# Server-only. From your Flutterwave dashboard -> Settings -> API Keys.
FLUTTERWAVE_SECRET_KEY=
# Server-only. Flutterwave dashboard -> Settings -> Webhooks -> "Secret hash" (your own arbitrary string, not provider-generated).
FLUTTERWAVE_SECRET_HASH=
